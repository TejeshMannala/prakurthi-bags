# Backend API URL
# - Leave EMPTY for same-origin setup (backend serves frontend build)
# - Set to your backend URL only if frontend and backend are on different origins
#
# Examples:
#   Local dev:            (leave empty - CRA proxy handles it)
#   Render single service: (leave empty - same origin)
#   Render separate:       https://prakurthi-bags-backend.onrender.com/api
#   Vercel frontend:       https://prakurthi-bags-backend.onrender.com/api
REACT_APP_API_URL=

# Google OAuth Client ID (from Google Cloud Console) - must match backend GOOGLE_CLIENT_ID.
# IMPORTANT: Add your production domain to "Authorized JavaScript origins" in Google Cloud Console.
REACT_APP_GOOGLE_CLIENT_ID=1052060626452-mb43897e734pq77kjsmthk10gi49ddsu.apps.googleusercontent.com
