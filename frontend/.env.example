# Backend API URL
# IMPORTANT: Set to the backend ORIGIN only (no /api suffix).
# All API calls already include /api/ in their paths.
#
# Examples:
#   Local dev:             (leave empty - CRA proxy handles it)
#   Render single service: (leave empty - same origin)
#   Render separate:       https://prakurthi-bags.onrender.com
#
# For production builds, use .env.production or set in Render dashboard.
REACT_APP_API_URL=https://prakurthi-bags.onrender.com

# Google OAuth Client ID (from Google Cloud Console) - must match backend GOOGLE_CLIENT_ID.
# IMPORTANT: Add both frontend origins to "Authorized JavaScript origins" in Google Cloud Console:
#   1. https://prakurthi-bags-1-frontend.onrender.com  (or your Render frontend URL)
#   2. https://prakurthi-bags.onrender.com              (backend, if also serving frontend)
REACT_APP_GOOGLE_CLIENT_ID=1052060626452-mb43897e734pq77kjsmthk10gi49ddsu.apps.googleusercontent.com
