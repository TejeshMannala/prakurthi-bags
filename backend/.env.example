PORT=5000
NODE_ENV=development

# MongoDB - replace with your connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/prakurthi-bags?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=30d

# Admin credentials (stored in env, NOT in MongoDB)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongAdminPassword123
ADMIN_NAME=Administrator

# Frontend URL (for CORS) - SET THIS to your deployed frontend URL
# Examples:
#   Render single service:  https://prakurthi-bags.onrender.com
#   Render separate:        https://prakurthi-bags-frontend.onrender.com
#   Vercel:                 https://prakruthi-bags.vercel.app
FRONTEND_URL=http://localhost:3000

# Google OAuth
# This MUST be identical to REACT_APP_GOOGLE_CLIENT_ID in frontend/.env
# The frontend GOOGLE_CLIENT_ID (1052060626452-...) is already consistent.
#
# REQUIRED (fixes "origin_mismatch" / "Error 400"): in Google Cloud Console
#   -> APIs & Services -> Credentials -> the Web client ID above
#   -> "Authorized JavaScript origins" MUST list EVERY origin that loads the
#      Google button, e.g.:
#        https://prakurthi-bags.onrender.com
#        https://prakurthi-bags-1-frontend.onrender.com
#        http://localhost:3000
#   -> "Authorized redirect URIs" should include:
#        https://prakurthi-bags.onrender.com
# Also set GOOGLE_CLIENT_SECRET from the same console page.
GOOGLE_CLIENT_ID=1052060626452-mb43897e734pq77kjsmthk10gi49ddsu.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# SMTP / Email (for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Redis (for caching products/categories — optional, skip if not using)
# REDIS_URL=redis://localhost:6379

# Cloudinary (for image uploads - optional)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
